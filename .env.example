# LLM 网关配置（变量名沿用 QWEN_ 前缀，但后端走 OpenAI 兼容协议，可指向任意兼容网关）
# 当前默认：阿里云百炼 + qwen3.6-plus
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.6-plus
# 摘要类"短而快"的任务（file/folder/project summary）走 fast 模型；同模型也行
# 空或不设 → 与 QWEN_MODEL 一致（等价禁用分层）
QWEN_FAST_MODEL=qwen3.6-plus
# qwen3.x 系列需显式关闭思考，否则 TTFT 高数倍
QWEN_ENABLE_THINKING=false

# 备选：sub2api 中转 + MiniMax-M2.7
# QWEN_BASE_URL=https://sub2api.eaislab.com/v1
# QWEN_MODEL=MiniMax-M2.7
# QWEN_FAST_MODEL=MiniMax-M2.7
# # minimax 支持 enable_thinking 开关，摘要关思考、agent 保留默认
# # QWEN_ENABLE_THINKING=false
